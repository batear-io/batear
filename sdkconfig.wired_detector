# Board (determines set-target chip and flash size)
CONFIG_BATEAR_BOARD_LILYGO_T_ETH_LITE_S3=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# OTA: two app partitions for safe rollback
CONFIG_PARTITION_TABLE_TWO_OTA=y
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# PSRAM (LILYGO T-ETH-Lite S3 has on-board 8 MB OPI PSRAM, ESP32-S3R8).
# Enabled so the TF recorder pre-roll ring buffer (~160 KB at 5 s @ 16 kHz s16)
# lives off-chip and leaves internal SRAM for I2S DMA + FFT.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
# Anything <= 16 KB stays in internal SRAM (audio buffers, DMA descriptors).
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
# I2S DMA descriptors must NOT live in PSRAM.
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=n

# Role
CONFIG_BATEAR_ROLE_WIRED_DETECTOR=y
CONFIG_BATEAR_DEVICE_ID=1

# MQTT / Home Assistant (override via NVS "wired_cfg" namespace)
CONFIG_BATEAR_MQTT_BROKER_URL="mqtt://{BROKER_IP}:1883"
CONFIG_BATEAR_MQTT_USER=""
CONFIG_BATEAR_MQTT_PASS=""
CONFIG_BATEAR_WIRED_DEVICE_ID="wd01"

# Ethernet — static IP (leave empty for DHCP)
CONFIG_BATEAR_ETH_STATIC_IP=""
CONFIG_BATEAR_ETH_GATEWAY=""
CONFIG_BATEAR_ETH_NETMASK="255.255.255.0"
CONFIG_BATEAR_ETH_DNS=""

# REST API
CONFIG_BATEAR_HTTP_PORT=8080
CONFIG_BATEAR_HTTP_AUTH_TOKEN="MyS3cretToken"

# TF card recording (always compiled in for Wired Detector; runtime no-op if no card)
CONFIG_BATEAR_TF_PREROLL_SEC=5
CONFIG_BATEAR_TF_POSTROLL_SEC=10
CONFIG_BATEAR_TF_MAX_MB=1024
CONFIG_BATEAR_TF_RECORD_ALWAYS=n
CONFIG_BATEAR_TF_MANUAL_ENABLE=y
CONFIG_BATEAR_TF_MANUAL_SEC=30
CONFIG_BATEAR_TF_NTP_SERVER="pool.ntp.org"
