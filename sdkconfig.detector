# Board (determines set-target chip and flash size)
CONFIG_BATEAR_BOARD_HELTEC_V3=y
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y

# Role
CONFIG_BATEAR_ROLE_DETECTOR=y
CONFIG_BATEAR_DEVICE_ID=1

# Network (must match between all detectors and gateway)
CONFIG_BATEAR_NET_KEY="DEADBEEFCAFEBABE13374200F00DAA55"
CONFIG_BATEAR_LORA_FREQ=915000
CONFIG_BATEAR_LORA_SYNC_WORD=0x12

# Telemetry heartbeat (jittered ±10% in firmware)
CONFIG_BATEAR_TELEMETRY_HEARTBEAT_MIN=30

# TinyML detector (TFLite Micro). Heltec V3 has no PSRAM — arena lives in
# internal SRAM, so keep it tight. Skeleton ships with drone_v0_dummy.tflite.
CONFIG_BATEAR_DETECT_USE_ML=y
CONFIG_BATEAR_ML_TENSOR_ARENA_KB=100
CONFIG_BATEAR_ML_CONF_ON_PCT=30
CONFIG_BATEAR_ML_CONF_OFF_PCT=18
